# Normalize line endings for text files
* text=auto eol=lf

# Godot text formats
*.gd text
*.tscn text
*.tres text
*.godot text
*.cfg text
*.import text

# Binary assets — never diff or merge these
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.svg text
*.ogg binary
*.wav binary
*.mp3 binary
*.ttf binary
*.otf binary
*.glb binary
*.gltf text
*.blend binary
